{
  "openapi": "3.0.1",
  "info": {
    "title": "PixPaymentSystem.API",
    "version": "1.0"
  },
  "paths": {
    "/Pix": {
      "post": {
        "tags": [
          "Pix"
        ],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PixRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PixRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PixRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Pix/{id}": {
      "get": {
        "tags": [
          "Pix"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PixRequestDto": {
        "type": "object",
        "properties": {
          "tipo": {
            "type": "string",
            "nullable": true
          },
          "valor": {
            "type": "number",
            "format": "double"
          },
          "dataAgendamento": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "frequenciaDias": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "dataFim": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}